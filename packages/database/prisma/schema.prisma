generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url       = env("DATABASE_URL")
  // directUrl = env("DIRECT_URL")
}

enum Role {
  STAFF
  ADMIN
}

model User {
  id          String   @id @default(uuid())
  name        String
  email       String?
  password    String
  phoneNumber String?
  staffId     String?  @unique
  city        String?
  department  String?
  unit        String?
  role        Role     @default(STAFF)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions AssessmentSession[]

  @@map("users")
}

model AssessmentSession {
  id                   String    @id @default(uuid())
  userId               String
  scenarioId           String
  difficultyLevel      String
  language             String    @default("Hinglish")
  status               String    @default("in_progress")
  totalDurationSeconds Int?
  startedAt            DateTime  @default(now())
  completedAt          DateTime?
  assessmentScores     Json?

  user     User     @relation(fields: [userId], references: [id])
  scenario Scenario @relation(fields: [scenarioId], references: [id])

  evaluationResults EvaluationResult[]
  stageResults      StageResult[]

  @@map("assessment_sessions")
}

model EvaluationResult {
  id         String   @id @default(uuid())
  sessionId  String
  stage      String
  evalPrompt String?
  evalResult Json?
  createdAt  DateTime @default(now())

  session AssessmentSession @relation(fields: [sessionId], references: [id])

  @@map("evaluation_results")
}

model Scenario {
  id                 String   @id @default(uuid())
  title              String
  description        String
  difficulty         String[]
  type               String
  isActive           Boolean  @default(true)
  departments        String[]
  createdAt          DateTime @default(now())
  roleplayPrompt     String?
  examinerPrompt     String?
  roleplayEvalPrompt String?
  examinerEvalPrompt String?

  // Agent Config
  introConfig    Json?
  roleplayConfig Json?
  examinerConfig Json?

  sessions AssessmentSession[]

  @@map("scenarios")
}

model StageResult {
  id                 String   @id @default(uuid())
  sessionId          String
  stage              String
  transcriptionJson  Json?
  transcript         String?
  audioUrl           String?
  videoUrl           String?
  durationSeconds    Int?
  createdAt          DateTime @default(now())
  diarizedTranscript String?
  speakerLabels      Json?

  session AssessmentSession @relation(fields: [sessionId], references: [id])

  @@map("stage_results")
}
